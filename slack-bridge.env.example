# Copy this file to /opt/urba-apps/discord-bot/slack-bridge.env on the server
# and fill in real values there. Do not commit real tokens.

SLACK_APP_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# App-Level Token from Basic Information -> App-Level Tokens with
# connections:write. Starts with xapp-.
SLACK_APP_TOKEN=

# Bot User OAuth Token from OAuth & Permissions. Starts with xoxb-.
SLACK_BOT_TOKEN=

SLACK_CHANNEL_ID=C0BCRVC2C6Q
SLACK_SOCKET_MODE=1

# Normal #bot messages can be forwarded to the official Codex Slack app.
# This uses Codex/ChatGPT subscription auth through the official app, not an
# OpenAI API key.
SLACK_CODEX_FORWARD=1
SLACK_CODEX_USER_ID=
SLACK_CODEX_ENVIRONMENT=mavebot
SLACK_CODEX_REPOSITORY=dolphalala/mavebot
SLACK_CODEX_MIRROR_REPLIES=1
SLACK_CODEX_STATE_PATH=/shared/codex-forward-state.json

SLACK_BRIDGE_AUTOREPLY=0
