# Copy this file to /opt/urba-apps/discord-bot/.env on the server and fill in
# real values there. Do not commit real tokens.

DISCORD_TOKEN=
DISCORD_CLIENT_ID=1519063290058117170

# Use a guild ID while developing so slash command changes appear quickly.
# Leave blank to register global commands for every server where the bot is
# installed. Global command changes can take longer to appear in Discord.
DISCORD_GUILD_ID=

# Optional one-time cleanup for old guild-scoped commands that can make Discord
# show duplicates next to global commands.
DISCORD_CLEAR_GUILD_COMMANDS_ID=

HEALTH_HOST=0.0.0.0
HEALTH_PORT=4188

COC_API_BASE_URL=https://api.clashofclans.com/v1
COC_API_TOKEN=
